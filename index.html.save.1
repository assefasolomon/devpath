<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Learn Full-Stack Web Development | DevPath</title>
  <link rel="stylesheet" href="css/styles.css">
  <style>
    /* ── PRICING SECTION ── */
    .pricing-section {
      padding: 5rem 2rem 3rem;
      max-width: 1100px;
      margin: 0 auto;
    }
    .pricing-eyebrow {
      text-align: center;
      font-family: var(--font-mono);
      font-size: .72rem;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: var(--secondary);
      margin-bottom: .75rem;
    }
    .pricing-title {
      text-align: center;
      font-size: 1.75rem;
      font-weight: 700;
      color: var(--heading);
      margin-bottom: .4rem;
    }
    .pricing-sub {
      text-align: center;
      color: var(--text-muted);
      font-size: .95rem;
      margin-bottom: 3rem;
    }

    /* plan cards */
    .plan-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1.25rem;
      margin-bottom: 3rem;
    }
    .plan-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      padding: 2rem;
      position: relative;
      transition: all var(--transition);
      cursor: pointer;
    }
    .plan-card:hover {
      transform: translateY(-4px);
      box-shadow: var(--shadow);
    }
    .plan-card.featured {
      border: 2px solid var(--accent);
    }
    .plan-card.selected {
      border: 2px solid var(--primary);
      box-shadow: 0 0 0 4px rgba(37,99,235,.12);
    }
    .plan-badge {
      position: absolute;
      top: -13px; left: 50%;
      transform: translateX(-50%);
      background: var(--accent);
      color: #000;
      font-size: .7rem;
      font-weight: 700;
      padding: 3px 14px;
      border-radius: 20px;
      white-space: nowrap;
      font-family: var(--font-mono);
      text-transform: uppercase;
      letter-spacing: .06em;
    }
    .plan-icon {
      font-size: 1.6rem;
      margin-bottom: .75rem;
    }
    .plan-name {
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--heading);
      margin-bottom: .25rem;
    }
    .plan-desc {
      font-size: .85rem;
      color: var(--text-muted);
      margin-bottom: 1.25rem;
      line-height: 1.6;
    }
    .plan-price {
      display: flex;
      align-items: baseline;
      gap: 6px;
      margin-bottom: 1.25rem;
    }
    .price-amount {
      font-size: 2.4rem;
      font-weight: 700;
      color: var(--heading);
    }
    .price-period {
      font-size: .82rem;
      color: var(--text-muted);
      font-family: var(--font-mono);
    }
    .price-was {
      font-size: .82rem;
      color: var(--text-muted);
      text-decoration: line-through;
      margin-left: 4px;
    }
    .plan-features {
      list-style: none;
      margin-bottom: 1.5rem;
    }
    .plan-features li {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: .875rem;
      color: var(--text);
      padding: 5px 0;
      border-bottom: 1px solid var(--border);
    }
    .plan-features li:last-child { border-bottom: none; }
    .feat-y { color: var(--green); }
    .feat-n { color: var(--border); }
    .feat-na { opacity: .35; }
    .plan-btn {
      width: 100%;
      padding: .75rem;
      border-radius: var(--radius);
      font-size: .9rem;
      font-weight: 700;
      cursor: pointer;
      transition: all var(--transition);
      font-family: var(--font-ui);
    }
    .plan-btn-outline {
      background: transparent;
      border: 1px solid var(--border);
      color: var(--text);
    }
    .plan-btn-outline:hover {
      border-color: var(--primary-light);
      color: var(--primary-light);
    }
    .plan-btn-solid {
      background: var(--primary);
      border: none;
      color: #fff;
    }
    .plan-btn-solid:hover { background: var(--primary-hover); }

    /* checkout box */
    .checkout-box {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      padding: 2rem;
      max-width: 600px;
      margin: 0 auto 2rem;
    }
    .checkout-title {
      font-size: 1.05rem;
      font-weight: 700;
      color: var(--heading);
      margin-bottom: 1.5rem;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .checkout-title em {
      font-style: normal;
      color: var(--green);
    }
    .selected-plan-bar {
      background: var(--surface-2);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 1rem 1.25rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 1.5rem;
    }
    .selected-plan-name {
      font-size: .95rem;
      font-weight: 700;
      color: var(--heading);
    }
    .selected-plan-sub {
      font-size: .75rem;
      color: var(--text-muted);
      font-family: var(--font-mono);
      margin-top: 2px;
    }
    .selected-plan-price {
      font-size: 1.6rem;
      font-weight: 700;
      color: var(--accent);
    }
    .pm-label {
      font-family: var(--font-mono);
      font-size: .7rem;
      text-transform: uppercase;
      letter-spacing: .1em;
      color: var(--text-muted);
      margin-bottom: .6rem;
    }
    .pm-tabs {
      display: flex;
      gap: 8px;
      margin-bottom: 1.5rem;
      flex-wrap: wrap;
    }
    .pm-tab {
      background: var(--surface-2);
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      padding: 7px 16px;
      color: var(--text-muted);
      font-size: .85rem;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 6px;
      transition: all var(--transition);
      font-family: var(--font-ui);
    }
    .pm-tab:hover { border-color: var(--primary); color: var(--text); }
    .pm-tab.active {
      border-color: var(--primary);
      color: var(--primary-light);
      background: var(--primary-glow);
    }
    .form-field { margin-bottom: 1rem; }
    .form-field label {
      display: block;
      font-family: var(--font-mono);
      font-size: .7rem;
      text-transform: uppercase;
      letter-spacing: .08em;
      color: var(--text-muted);
      margin-bottom: 5px;
    }
    .form-field input {
      width: 100%;
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      padding: 9px 12px;
      color: var(--heading);
      font-size: .9rem;
      font-family: var(--font-ui);
      outline: none;
      transition: border-color var(--transition);
    }
    .form-field input:focus { border-color: var(--primary); }
    .form-field input::placeholder { color: var(--text-muted); opacity: .5; }
    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }
    .method-alt {
      background: var(--surface-2);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 1.5rem;
      text-align: center;
      color: var(--text-muted);
      font-size: .9rem;
      display: none;
      margin-bottom: 1rem;
    }
    .method-alt .alt-icon {
      font-size: 2rem;
      margin-bottom: .5rem;
    }
    .secure-note {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: .78rem;
      color: var(--text-muted);
      font-family: var(--font-mono);
      margin: 1rem 0;
    }
    .secure-note .lock { color: var(--green); }
    .pay-btn {
      width: 100%;
      padding: .85rem;
      background: var(--primary);
      color: #fff;
      border: none;
      border-radius: var(--radius);
      font-size: 1rem;
      font-weight: 700;
      cursor: pointer;
      font-family: var(--font-ui);
      transition: all var(--transition);
    }
    .pay-btn:hover { background: var(--primary-hover); }
    .pay-btn.success { background: var(--green); cursor: default; }

    /* ── FAQ ── */
    .faq-section {
      max-width: 720px;
      margin: 0 auto;
      padding: 0 2rem 5rem;
    }
    .faq-item {
      border-bottom: 1px solid var(--border);
      padding: 1.25rem 0;
    }
    .faq-q {
      font-size: .97rem;
      font-weight: 700;
      color: var(--heading);
      cursor: pointer;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 1rem;
      user-select: none;
    }
    .faq-q:hover { color: var(--secondary); }
    .faq-chev {
      color: var(--text-muted);
      font-size: 1rem;
      transition: transform var(--transition);
      flex-shrink: 0;
    }
    .faq-chev.open { transform: rotate(180deg); }
    .faq-a {
      font-size: .9rem;
      color: var(--text-muted);
      margin-top: .75rem;
      line-height: 1.75;
      display: none;
    }
    .faq-a.open { display: block; }

    /* ── FULL FOOTER ── */
    .footer-full {
      background: var(--surface);
      border-top: 1px solid var(--border);
      padding: 3.5rem 2rem 2rem;
    }
    .footer-inner { max-width: 1100px; margin: 0 auto; }
    .footer-grid {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr 1fr;
      gap: 2rem;
      margin-bottom: 2.5rem;
    }
    .footer-brand-name {
      display: flex;
      align-items: center;
      gap: .5rem;
      font-weight: 700;
      font-size: 1.1rem;
      color: var(--primary-light);
      margin-bottom: .75rem;
    }
    .footer-brand-name svg { width: 22px; height: 22px; }
    .footer-brand p {
      font-size: .85rem;
      color: var(--text-muted);
      line-height: 1.7;
      max-width: 240px;
    }
    .footer-col h4 {
      font-family: var(--font-mono);
      font-size: .7rem;
      text-transform: uppercase;
      letter-spacing: .1em;
      color: var(--text-muted);
      margin-bottom: 1rem;
    }
    .footer-col a {
      display: block;
      font-size: .875rem;
      color: var(--text-muted);
      margin-bottom: .5rem;
      transition: color var(--transition);
      text-decoration: none;
    }
    .footer-col a:hover { color: var(--secondary); }
    .footer-bottom {
      border-top: 1px solid var(--border);
      padding-top: 1.25rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 1rem;
    }
    .footer-bottom p {
      font-size: .8rem;
      color: var(--text-muted);
      font-family: var(--font-mono);
    }
    .social-links { display: flex; gap: 10px; }
    .social-link {
      width: 32px; height: 32px;
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--text-muted);
      font-size: .75rem;
      font-weight: 700;
      transition: all var(--transition);
      text-decoration: none;
      font-family: var(--font-mono);
    }
    .social-link:hover {
      border-color: var(--primary);
      color: var(--primary-light);
    }

    /* path-grid one row */
    .path-grid {
      display: flex;
      flex-wrap: nowrap;
      gap: 1rem;
      overflow-x: auto;
      padding-bottom: .5rem;
    }
    .path-card { flex: 1 1 0; min-width: 200px; }

    @media (max-width: 768px) {
      .footer-grid { grid-template-columns: 1fr 1fr; }
      .form-row { grid-template-columns: 1fr; }
      .path-grid { flex-wrap: wrap; }
    }
    @media (max-width: 480px) {
      .footer-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
