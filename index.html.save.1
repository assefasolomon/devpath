<script src="js/main.js"></script>
<script>
  const plans = {
    starter: { name: 'Starter plan', sub: 'Foundations path · 40+ lessons',       price: '$49'  },
    pro:     { name: 'Pro plan',     sub: 'All paths · AI mentor · 200+ lessons',  price: '$149' },
    team:    { name: 'Team plan',    sub: 'Up to 10 seats · Everything in Pro',     price: '$399' }
  };

  function selectPlan(id) {
    ['starter','pro','team'].forEach(p =>
      document.getElementById('card-'+p).classList.remove('selected')
    );
    document.getElementById('card-'+id).classList.add('selected');
    const p = plans[id];
    document.getElementById('plan-name-label').textContent  = p.name;
    document.getElementById('plan-sub-label').textContent   = p.sub;
    document.getElementById('plan-price-label').textContent = p.price;
    document.getElementById('pay-amount').textContent       = p.price;
    document.getElementById('checkout').scrollIntoView({ behavior:'smooth', block:'start' });
  }

  function switchMethod(m) {
    ['card','paypal','crypto'].forEach(x => {
      document.getElementById('tab-'+x).classList.remove('active');
      document.getElementById('form-'+x).style.display = 'none';
    });
    document.getElementById('tab-'+m).classList.add('active');
    document.getElementById('form-'+m).style.display = 'block';
  }

  function fmtCard(el) {
    let v = el.value.replace(/\D/g,'').substring(0,16);
    el.value = v.replace(/(.{4})/g,'$1 ').trim();
  }

  function toggleFaq(i) {
    const a = document.getElementById('faq-'+i);
    const c = document.getElementById('chev-'+i);
    const open = a.classList.contains('open');
    document.querySelectorAll('.faq-a').forEach(x => x.classList.remove('open'));
    document.querySelectorAll('.faq-chev').forEach(x => x.classList.remove('open'));
    if (!open) { a.classList.add('open'); c.classList.add('open'); }
  }

  function handlePay() {
    const btn = document.getElementById('pay-btn');
    const amt = document.getElementById('pay-amount').textContent;
    if (amt === '—') { alert('Please select a plan first.'); return; }
    btn.textContent = 'Processing...';
    btn.disabled = true;
    btn.style.opacity = '.6';
    setTimeout(() => {
      btn.textContent = '✓ Payment successful — check your email!';
      btn.classList.add('success');
      btn.style.opacity = '1';
    }, 1800);
  }

  document.getElementById('form-paypal').style.display = 'none';
  document.getElementById('form-crypto').style.display = 'none';
</script>
