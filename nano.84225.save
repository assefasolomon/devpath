def main():
    seed_intermediate_html_css()
    print("\nCommitting...")
    os.chdir(BASE)
    subprocess.run(["git","add","-A"], check=True)
    subprocess.run(["git","commit","-m","Seed Intermediate HTML & CSS (15 lessons)"], check=True)
    subprocess.run(["git","push"], check=True)
    print("Done.")

if __name__ == "__main__":
    main()




























